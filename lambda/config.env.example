# Copia a config.env y rellena (config.env no debe commitearse).
# Uso: desde la raíz del repo, bash lambda/deploy.sh

# Obligatorio
AWS_REGION=us-east-1

# VPC: vacío = VPC por defecto de la cuenta en esa región
# VPC_ID=vpc-xxxxxxxx

# DocumentDB (clúster lógico en AWS; la base Mongo se llama opensanctions al restaurar)
DOCDB_CLUSTER_ID=opensanctions-docdb
DOCDB_INSTANCE_ID=opensanctions-docdb-1
DOCDB_MASTER_USERNAME=opensanctionsadmin
# Mín. 8 caracteres, mayúsculas, minúsculas, números (restricciones AWS)
DOCDB_MASTER_PASSWORD=CambiarPorUnaClaveSegura1

# DocumentDB no ofrece instancias de exactamente 2 GiB; la más cercana con ~2 vCPU suele ser db.t4g.medium (4 GiB).
DOCDB_INSTANCE_CLASS=db.t4g.medium

# Grupo de subredes (se crea si no existe)
DOCDB_SUBNET_GROUP_NAME=opensanctions-docdb-subnets

# Nombres de security groups (se crean si no existen)
DOCDB_SECURITY_GROUP_NAME=opensanctions-docdb-sg
LAMBDA_SECURITY_GROUP_NAME=opensanctions-lambda-sg

# Mongo / restauración (misma base que usa la app)
MONGO_DB=opensanctions

# Carpeta de backups (relativa a la raíz del repo)
BACKUPS_DIR=backups

# Saltar mongorestore si solo quieres actualizar Lambda
# SKIP_RESTORE=1

# Lambda
LAMBDA_FUNCTION_NAME=opensanctions-api
LAMBDA_ROLE_NAME=opensanctions-lambda-exec
LAMBDA_RUNTIME=nodejs20.x
LAMBDA_TIMEOUT=60
LAMBDA_MEMORY=1024

# Subredes para la Lambda (misma VPC que DocumentDB). Vacío = dos subredes distintas de la VPC elegida.
# LAMBDA_SUBNET_IDS=subnet-aaa,subnet-bbb

# RapidAPI (opcional; se inyectan en variables de entorno de la Lambda al desplegar)
# rapid_api=true
# RAPIDAPI_PROXY_SECRET=
