# Desarrollo local
MONGO_URI=mongodb://localhost:27017
MONGO_DB=opensanctions
PORT=3000

# Modo de búsqueda:
# - '1'/'true'/'yes' => lite (busca solo por `id` y `caption`, sin `searchableText`/properties)
# - vacío => full (busca también sobre `searchableText` derivado de properties)
OPENSANCTIONS_SEARCH_LITE=

# Producción (contenedor Docker): pasar MONGO_URI al run, ej.:
# -e MONGO_URI=mongodb://host.docker.internal:27017
# -e MONGO_URI=mongodb://mongo:27017   (si mongo está en la misma red Docker)
# -e MONGO_DB=analytikoDB3   (opcional, si usas otra base)
